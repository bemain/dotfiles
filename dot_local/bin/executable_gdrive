#!/usr/bin/env bash

# --- Configuration ---
CONFIG_DIR="$HOME/.config/gdrive-sync"
CONFIG_FILE="$CONFIG_DIR/config.yml"
REMOTE="gdrive:"

# Recommended comparison flags for reliability
BISYNC_FLAGS="--create-empty-src-dirs --verbose --compare size,modtime --modify-window 1s --drive-skip-gdocs"

# Ensure config directory and valid YAML file exist
mkdir -p "$CONFIG_DIR"
if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "targets: []" > "$CONFIG_FILE"
fi

yq() {
	distrobox enter fedora -- yq "$@"
}

rclone() {
	distrobox enter fedora -- rclone "$@"
}


# --- Helper: Perform Sync ---
do_sync() {
    local local_path="$1"
    local remote_subpath="$2"
    local extra_flags="$3"

    local remote_full_path="${REMOTE}${remote_subpath}"

    if [[ -d "$local_path" ]]; then
        echo "Action: Syncing Directory [$local_path] <-> [$remote_full_path]"
        rclone bisync "$remote_full_path" "$local_path" $BISYNC_FLAGS $extra_flags
        
    elif [[ -f "$local_path" ]]; then
        local parent_dir=$(dirname "$local_path")
        local filename=$(basename "$local_path")
        
        # Determine the remote parent directory
        local remote_parent=$(dirname "$remote_subpath")
        [[ "$remote_parent" == "." ]] && remote_parent=""
        local remote_full_parent="${REMOTE}${remote_parent}"

        echo "Action: Syncing File [$local_path] <-> [${REMOTE}${remote_subpath}]"
        rclone bisync "$remote_full_parent" "$parent_dir" --include "/$filename" $BISYNC_FLAGS $extra_flags
    else
        echo "Error: Local path '$local_path' not found."
        return 1
    fi
}

# --- Functions ---

add_path() {
    if [[ -z "$1" ]]; then
        echo "Usage: gdrive add <local_path> [remote_path]"
        echo "Example (explicit): gdrive add ~/Docs backup/docs"
        echo "Example (auto):     gdrive add ~/Docs  # Syncs to 'gdrive:Docs'"
        exit 1
    fi

    local local_path=$(realpath "$1")
    local remote_path="$2"

    # If remote_path is not provided, use the name of the local file/folder
    if [[ -z "$remote_path" ]]; then
        remote_path=$(basename "$local_path")
    fi

    [[ ! -e "$local_path" ]] && echo "Error: Local path does not exist." && exit 1
    
    yq -i ".targets += [{\"local\": \"$local_path\", \"remote\": \"$remote_path\"}]" "$CONFIG_FILE"
    yq -i ".targets |= unique_by(.local)" "$CONFIG_FILE"
    
    echo "Success: Added mapping:"
    echo "  Local:  $local_path"
    echo "  Remote: $REMOTE$remote_path"
}

remove_path() {
    if [[ -z "$1" ]]; then
        echo "Usage: gdrive remove <local_path>"
        exit 1
    fi
    local local_path=$(realpath "$1")

    if yq -e ".targets[] | select(.local == \"$local_path\")" "$CONFIG_FILE" >/dev/null 2>&1; then
        yq -i ".targets |= del(.[] | select(.local == \"$local_path\"))" "$CONFIG_FILE"
        echo "Success: Removed '$local_path' from sync config."
    else
        echo "Error: No mapping found for local path '$local_path'."
    fi
}

resync_path() {
    if [[ -z "$1" ]]; then
        echo "Usage: gdrive resync <local_path>"
        exit 1
    fi
    local local_path=$(realpath "$1")
    local remote_path=$(yq ".targets[] | select(.local == \"$local_path\") | .remote" "$CONFIG_FILE")

    if [[ -z "$remote_path" || "$remote_path" == "null" ]]; then
        echo "Error: '$local_path' is not in config. Use 'gdrive add' first."
        exit 1
    fi

    echo "Performing INITIAL resync..."
    do_sync "$local_path" "$remote_path" "--resync"
}

sync_all() {
    local count=$(yq '.targets | length' "$CONFIG_FILE")
    [[ "$count" -eq 0 ]] && echo "No paths in config. Use 'gdrive add' first." && exit 0

    echo "Starting Google Drive Sync ($count targets)..."
    for ((i=0; i<$count; i++)); do
        local lp=$(yq ".targets[$i].local" "$CONFIG_FILE")
        local rp=$(yq ".targets[$i].remote" "$CONFIG_FILE")
        do_sync "$lp" "$rp" "" || echo "Tip: Use 'gdrive resync $lp' if this is the first run."
        echo "---"
    done
}

# --- Main Logic ---

case "$1" in
    add)     add_path "$2" "$3" ;;
    remove)  remove_path "$2" ;;
    sync)    sync_all ;;
    resync)  resync_path "$2" ;;
    list)  yq '.' "$CONFIG_FILE" ;;
    *)
        echo "gdrive CLI — easily sync files to Google Drive."
        echo "  gdrive add <local> [remote]	: Add path to config"
        echo "  gdrive remove <local> 		: Remove path from config"
        echo "  gdrive sync          		: Sync all configured paths"
        echo "  gdrive resync <local> 		: Force a first-time/full resync for a specific path"
        echo "  gdrive list          		: List configured paths"
        exit 1
        ;;
esac
