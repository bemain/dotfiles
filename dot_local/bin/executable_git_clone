#!/usr/bin/env bash

# 1. Ask for the Repo URL if not provided
URL=$1
if [ -z "$URL" ]; then
    echo "Usage: git_clone <repository_url>"
    return 1
fi

# 2. Extract folder name from URL to enter it later
FOLDER=$(basename "$URL" .git)

# 3. Perform the initial clone
git clone "$URL"
if [ $? -ne 0 ]; then return 1; fi
cd "$FOLDER" || return

source git_setup || exit 1
